---
const invites = [
    { year: 2025, link: '/2025/' },
    { year: 2024 },
    { year: 2023 },
    { year: 2022 },
    { year: 2021 },
    { year: 2019 },
    { year: 2017 },
    { year: 2016 },
];
---
<section class="gallery-section">
    <div class="gallery-header">
        <span class="gallery-rule"></span>
        <h2 class="section-title">The Archive</h2>
        <span class="gallery-rule"></span>
    </div>

    <div class="timeline">
        <nav class="timeline-nav" aria-label="Year navigation">
            <div class="timeline-track">
                {invites.map((invite) => (
                    <a href={`#year-${invite.year}`} class="timeline-dot-link" data-year={invite.year}>
                        <span class="dot"></span>
                        <span class="dot-year">{invite.year}</span>
                    </a>
                ))}
            </div>
        </nav>

        <div class="timeline-content">
            {invites.map((invite) => (
                <div class="timeline-item" id={`year-${invite.year}`}>
                    <div class="timeline-item-year">
                        <span class="year-number">{invite.year}</span>
                    </div>
                    <div class="timeline-item-card">
                        <div class="card-image">
                            {invite.link ? (
                                <a href={invite.link} class="card-link">
                                    <img src={`/invites/hipster-holiday-${invite.year}.jpg`} alt={`Hipster Holiday ${invite.year}`} loading="lazy" />
                                    <span class="view-site">View Site &rarr;</span>
                                </a>
                            ) : (
                                <img src={`/invites/hipster-holiday-${invite.year}.jpg`} alt={`Hipster Holiday ${invite.year}`} loading="lazy" />
                            )}
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<script>
    const items = document.querySelectorAll('.timeline-item');
    const dotLinks = document.querySelectorAll('.timeline-dot-link');

    function updateActiveDot() {
        const scrollCenter = window.innerHeight * 0.45;
        let activeYear = '';

        items.forEach((item) => {
            const rect = item.getBoundingClientRect();
            if (rect.top < scrollCenter && rect.bottom > scrollCenter - 100) {
                activeYear = item.id;
            }
        });

        dotLinks.forEach((link) => {
            const isActive = `year-${link.getAttribute('data-year')}` === activeYear;
            link.classList.toggle('active', isActive);
        });
    }

    window.addEventListener('scroll', updateActiveDot, { passive: true });
    updateActiveDot();

    dotLinks.forEach((link) => {
        link.addEventListener('click', (e) => {
            e.preventDefault();
            const target = document.getElementById(`year-${link.getAttribute('data-year')}`);
            if (target) {
                target.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        });
    });
</script>

<style>
    .gallery-section {
        max-width: 1100px;
        width: 100%;
        margin: 0 auto;
        padding: 64px 32px 120px;
        position: relative;
        z-index: 1;
    }

    .gallery-header {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 24px;
        margin-bottom: 72px;
    }

    .gallery-rule {
        display: block;
        flex: 1;
        max-width: 120px;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--gold), transparent);
        opacity: 0.5;
    }

    .section-title {
        font-family: var(--font-display);
        font-weight: 400;
        font-style: italic;
        font-size: 32px;
        color: var(--text-primary);
        text-align: center;
        letter-spacing: 0.02em;
    }

    .timeline {
        display: flex;
        gap: 0;
    }

    .timeline-nav {
        position: sticky;
        top: 50%;
        transform: translateY(-50%);
        height: fit-content;
        flex-shrink: 0;
        align-self: flex-start;
        width: 80px;
    }

    .timeline-track {
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
        padding: 16px 0;
    }

    .timeline-track::before {
        content: '';
        position: absolute;
        top: 16px;
        bottom: 16px;
        left: 50%;
        width: 1px;
        background: rgba(255, 255, 255, 0.06);
        transform: translateX(-50%);
    }

    .timeline-dot-link {
        position: relative;
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 14px 0;
        text-decoration: none;
        cursor: pointer;
        z-index: 1;
    }

    .dot {
        display: block;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.12);
        border: 1.5px solid rgba(255, 255, 255, 0.08);
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .dot-year {
        font-family: var(--font-body);
        font-weight: 400;
        font-size: 12px;
        letter-spacing: 1px;
        color: var(--text-dim);
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        white-space: nowrap;
    }

    .timeline-dot-link:hover .dot {
        background: rgba(255, 255, 255, 0.3);
        transform: scale(1.3);
    }

    .timeline-dot-link:hover .dot-year {
        color: var(--text-mid);
    }

    .timeline-dot-link.active .dot {
        background: var(--accent);
        border-color: var(--accent);
        transform: scale(1.5);
        box-shadow: 0 0 12px rgba(196, 52, 45, 0.5);
    }

    .timeline-dot-link.active .dot-year {
        color: var(--text-primary);
        font-weight: 500;
    }

    .timeline-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 80px;
        min-width: 0;
        padding-left: 32px;
    }

    .timeline-item {
        display: flex;
        align-items: flex-start;
        gap: 32px;
        scroll-margin-top: 25vh;
    }

    .timeline-item-year {
        flex-shrink: 0;
        width: 64px;
        padding-top: 20px;
    }

    .year-number {
        font-family: var(--font-display);
        font-size: 20px;
        color: var(--text-dim);
        writing-mode: vertical-lr;
        text-orientation: mixed;
        letter-spacing: 2px;
        transform: rotate(180deg);
    }

    .timeline-item-card {
        flex: 1;
        min-width: 0;
    }

    .card-image {
        position: relative;
        border-radius: 12px;
        overflow: hidden;
        background: var(--bg-card);
        box-shadow: 0 8px 40px rgba(0, 0, 0, 0.4);
    }

    .card-image img {
        width: 100%;
        display: block;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .card-image:hover img {
        transform: scale(1.03);
    }

    .card-link {
        display: block;
        position: relative;
    }

    .view-site {
        position: absolute;
        bottom: 16px;
        right: 16px;
        font-family: var(--font-body);
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--text-primary);
        background: rgba(6, 8, 16, 0.7);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        padding: 8px 16px;
        border-radius: 100px;
        opacity: 0;
        transform: translateY(4px);
        transition: opacity 0.3s, transform 0.3s;
    }

    .card-link:hover .view-site {
        opacity: 1;
        transform: translateY(0);
    }

    @media (max-width: 768px) {
        .gallery-section {
            padding: 48px 20px 80px;
        }

        .gallery-header {
            margin-bottom: 40px;
        }

        .section-title {
            font-size: 26px;
        }

        .timeline {
            flex-direction: column;
        }

        .timeline-nav {
            position: static;
            transform: none;
            width: 100%;
            margin-bottom: 32px;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        .timeline-track {
            flex-direction: row;
            justify-content: center;
            flex-wrap: wrap;
            padding: 0;
        }

        .timeline-track::before {
            display: none;
        }

        .timeline-dot-link {
            flex-direction: column;
            padding: 8px 12px;
            gap: 6px;
        }

        .dot-year {
            font-size: 11px;
        }

        .timeline-content {
            padding-left: 0;
            gap: 48px;
        }

        .timeline-item {
            flex-direction: column;
            gap: 12px;
        }

        .timeline-item-year {
            width: auto;
            padding-top: 0;
        }

        .year-number {
            writing-mode: horizontal-tb;
            transform: none;
            font-size: 18px;
            color: var(--text-mid);
        }

        .card-image {
            border-radius: 10px;
        }

        .view-site {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
